<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/UI/Style.uss?fileID=7433441132597879392&amp;guid=27d4f12ebfe52461d95c1bcc01f10aac&amp;type=3#Style"/>
    <AnimatedButton text="Back" name="BackButton" icon-image="" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" display-tooltip-when-elided="false" class="GameModeButton" style="background-color: rgba(188, 188, 188, 0); width: 177px; margin-top: -1px; height: 81px; font-size: 64px;"/>
    <ui:Label text="Game mode" name="GameMode" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" display-tooltip-when-elided="false" class="GameModeLabel">
        <AnimatedButton name="Marathon" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" display-tooltip-when-elided="false" text="Marathon" class="GameModeButton GameModeButtonSelected"/>
        <AnimatedButton name="TimeLimit" enable-rich-text="false" emoji-fallback-support="false" triple-click-selects-line="false" display-tooltip-when-elided="false" double-click-selects-word="false" text="Time Attack" class="GameModeButton" style="margin-top: 10px;"/>
    </ui:Label>
    <ui:Label text="Settings" name="Settings" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" display-tooltip-when-elided="false" class="GameModeLabel">
        <ui:Label text="Level Start" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" display-tooltip-when-elided="false" name="LevelStartLabel" style="align-self: center; margin-top: 94px; margin-left: 47px; flex-direction: row; flex-wrap: wrap; width: 90%; justify-content: space-around;"/>
        <ui:VisualElement name="LevelStartParent" style="flex-grow: 1; flex-direction: row; width: 500px; flex-wrap: wrap; align-self: center; justify-content: center;">
