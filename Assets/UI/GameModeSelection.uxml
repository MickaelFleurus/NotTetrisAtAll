        <ui:VisualElement name="TimeLimitParent" style="flex-grow: 1; flex-direction: row; display: none;">
            <AnimatedButton text="1" name="1" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" display-tooltip-when-elided="false" triple-click-selects-line="false" class="GameModeLevelButton GameModeLevelButtonSelected"/>
            <AnimatedButton text="2" name="2" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" display-tooltip-when-elided="false" triple-click-selects-line="false" class="GameModeLevelButton"/>
