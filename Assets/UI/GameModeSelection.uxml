        <ui:Label text="BlockSize" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" display-tooltip-when-elided="false" name="BlockSizeLabel" style="align-self: center; margin-top: 60px; margin-left: 47px; flex-direction: row; flex-wrap: wrap; width: 90%; justify-content: space-around; height: 70px;"/>
        <ui:VisualElement name="BlockSizeParent" style="flex-grow: 1; flex-direction: row; width: 500px; justify-content: center; align-self: center; flex-wrap: wrap;">
