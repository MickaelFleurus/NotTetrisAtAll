    <AnimatedButton text="Start!" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" display-tooltip-when-elided="false" name="StartButton" class="StartScreenButton" style="margin-top: 26px; bottom: 0; position: absolute;"/>
