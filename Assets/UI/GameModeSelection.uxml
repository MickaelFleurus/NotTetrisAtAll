            <AnimatedButton text="6" name="6" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" display-tooltip-when-elided="false" triple-click-selects-line="false" class="GameModeLevelButton"/>
            <AnimatedButton text="7" name="7" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" display-tooltip-when-elided="false" triple-click-selects-line="false" class="GameModeLevelButton"/>
            <AnimatedButton text="8" name="8" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" display-tooltip-when-elided="false" triple-click-selects-line="false" class="GameModeLevelButton"/>
