        <ui:Label text="Size &lt; 3 and &gt;5 make the gameplay weird!" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" display-tooltip-when-elided="false" name="BlockSizeWarning" style="align-self: center; margin-top: 10px; margin-left: 0; flex-direction: row; flex-wrap: wrap; width: 90%; justify-content: space-around; -unity-text-align: upper-center; margin-right: 0; margin-bottom: 0; color: rgb(255, 102, 102); font-size: 33px; display: none;"/>
