            <AnimatedButton text="Start" name="StartButton" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" display-tooltip-when-elided="false" animate-on-focus="true" min-rotation="-4" max-rotation="4" min-scale="0.95" max-scale="1.05" scale-mode="Oscillate" scale-duration="0.9" rotation-activation="OnFocusIn" scale-activation="OnFocusIn" class="StartScreenButton" style="border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; width: 24%;"/>
            <ui:VisualElement name="Spacer" class="Spacer"/>
            <AnimatedButton text="Settings" name="SettingsButton" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" display-tooltip-when-elided="false" animate-on-focus="true" min-rotation="-4" max-rotation="4" min-scale="0.95" max-scale="1.05" scale-mode="Oscillate" scale-duration="0.9" rotation-activation="OnFocusIn" scale-activation="OnFocusIn" class="StartScreenButton" style="border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; width: 39%;"/>
            <ui:VisualElement name="Spacer" class="Spacer"/>
            <AnimatedButton text="Credits" name="CreditsButton" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" animate-on-focus="true" min-rotation="-4" max-rotation="4" min-scale="0.95" max-scale="1.05" scale-mode="Oscillate" display-tooltip-when-elided="false" scale-duration="0.9" rotation-activation="OnFocusIn" scale-activation="OnFocusIn" class="StartScreenButton" style="border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; width: 32%;"/>
            <ui:VisualElement name="Spacer" class="Spacer"/>
            <AnimatedButton text="Exit" name="ExitButton" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" animate-on-focus="true" min-rotation="-4" max-rotation="4" min-scale="0.95" max-scale="1.05" scale-mode="Oscillate" display-tooltip-when-elided="false" scale-duration="0.9" rotation-activation="OnFocusIn" scale-activation="OnFocusIn" class="StartScreenButton" style="border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; width: 18%;"/>
