    <AnimatedLabel text="Too Many&#10;Cubes" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" display-tooltip-when-elided="false" name="Title" animate-rotation="false" min-rotation="-11" max-rotation="11" rotation-duration="1" rotation-mode="Oscillate" animate-scale="true" min-scale="0.9" max-scale="1.1" scale-duration="0.8" scale-mode="Oscillate" rotation-activation="Always" scale-activation="Always" class="tiltLeft" style="color: rgb(255, 255, 255); -unity-text-align: upper-center; top: auto; font-size: 135px; margin-top: 10%; margin-bottom: 10%; -unity-font-definition: url(&quot;project://database/Assets/Fonts/Super%20Starfish.ttf?fileID=12800000&amp;guid=64b567f78eb144a20b4d5b5a10fc7395&amp;type=3#Super Starfish&quot;);"/>
    <ui:VisualElement name="ActionZone" style="flex-grow: 1;">
